<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Destined — Home ❤️‍🔥</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container home-container">
        
        <!-- Top Bar -->
        <div class="top-bar">
            <div class="top-left">
                <span class="notification-icon" onclick="showNotification()">🔔</span>
                <span class="search-icon">🔍</span>
            </div>
            <div class="top-right">
                <span class="logo-text">❤️‍🔥 DESTINED</span>
            </div>
        </div>

        <!-- Swipe Card -->
        <div class="swipe-card" id="swipeCard">
            <div class="card-image">
                <img id="profileImage" src="https://picsum.photos/seed/1/400/500" alt="Profile">
                <div class="card-overlay">
                    <h2 class="card-name"><span id="profileName">Sarah</span>, <span id="profileAge">28</span></h2>
                    <p class="card-location">📍 <span id="profileLocation">London</span></p>
                    <div class="card-badges">
                        <span class="badge-status">✅ Single</span>
                        <span class="badge-looking">💍 Open to Long-term</span>
                    </div>
                    <p class="card-bio" id="profileBio">"Love is the greatest adventure." ❤️‍🔥</p>
                </div>
            </div>
        </div>

        <!-- Swipe Buttons -->
        <div class="swipe-buttons">
            <button class="swipe-btn rewind" onclick="rewindSwipe()">↩️</button>
            <button class="swipe-btn pass" onclick="passSwipe()">❌</button>
            <button class="swipe-btn super-like" onclick="superLike()">⭐</button>
            <button class="swipe-btn like" onclick="likeSwipe()">💚</button>
            <button class="swipe-btn boost" onclick="boostProfile()">⚡</button>
        </div>

        <!-- Bottom Navigation -->
        <div class="bottom-nav">
            <a href="home.html" class="nav-item active">❤️‍🔥</a>
            <a href="#" class="nav-item">💞</a>
            <a href="#" class="nav-item">✨</a>
            <a href="#" class="nav-item">💬</a>
            <a href="#" class="nav-item" onclick="goToProfile()">👤</a>
        </div>

    </div>

    <script src="config.js"></script>
    <script src="script.js"></script>
</body>
</html>
